# Database
DATABASE_URL=your_supabase_postgresql_url_here
ADMIN_PASSWORD=your_admin_password
ADMIN_ALLOWED_EMAILS=admin1@example.com,admin2@example.com

# Supabase Storage
SUPABASE_URL=https://your-project-ref.supabase.co
SUPABASE_SERVICE_KEY=your_supabase_service_role_key_here

# OTP Email (SMTP)
# SMTP_MODE: starttls | ssl | plain
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_MODE=starttls
# Ưu tiên IPv4 khi deploy cloud (tránh lỗi Errno 101 với IPv6 route)
SMTP_PREFER_IPV4=true
# Danh sách cổng SMTP fallback, cách nhau bằng dấu phẩy (ví dụ: 465,2525)
SMTP_PORT_FALLBACKS=465,2525
SMTP_USER=your_email@gmail.com
SMTP_PASSWORD=your_app_password_here
SMTP_FROM=your_email@gmail.com

# OTP sender strategy: auto | smtp | resend | brevo_api
# auto = thử SMTP trước, fail thì fallback qua API HTTPS
OTP_EMAIL_PROVIDER=auto

# Optional fallback 1: Resend API (khuyên dùng khi SMTP deploy không ổn định)
# RESEND_API_KEY=re_xxx
# RESEND_FROM_EMAIL=NearBite <onboarding@resend.dev>

# Optional fallback 2: Brevo API
# BREVO_API_KEY=xkeysib-xxx
# BREVO_SENDER_EMAIL=your_verified_sender@example.com
# BREVO_SENDER_NAME=NearBite

# Optional for local testing when SMTP is not configured
OTP_DEBUG_FALLBACK=false

# Example:
# SUPABASE_URL=https://abcdefghijklmnop.supabase.co
# SUPABASE_SERVICE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...
